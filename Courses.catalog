            "9": [
            ], "10": [
                {   "id": "ECO110E110",
                    "name": "Economics & Business 10 Standard",
                    "track": "school",
                    "level": "S",
                    "description": "Economics and Business is a course combined with theories and applications of economics and basic understanding of business organizations and management. The Economics part covers three fundamental sections including Microeconomics, Macroeconomics and International Economics. The Business part covers functions and types of business and basic analytical tools. After one-year study of the course, students are expected to achieve the following goals: identify economics terms, understand economic theories and apply to real-life situations, draw economics diagrams to illustrate economic phenomenon, read and interpret economic data such as tables and graphs; understand function of business organizations; apply business analytical tools on real-life cases. Students will also have the opportunity to explore the most recent economic and business issues in the semester project. The course is offered at Standard level and Honors level. Standard level will have questions including multiple choices, theory interpretation and case studies, while Honors level will emphasize more on evaluation and application skills particularly on economics in the real world. The level will be decided after the first month of the first semester based on students' English level and first course test. Students should in English H, or have an equivalent TOEFL score of 100+ or an IELTS score of 7.5+. Students in Standard Level can move up to Honors level as long as they pass the move-up tests later after midterm or final exam. Homework expectations: 1-2 hours per week",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "next": [["ECO110E130"]] }
                }, { "id": "ECO110E130",
                    "name": "Economics & Business 10 Honors",
                    "track": "school",
                    "level": "H",
                    "description": "Economics and Business is a course combined with theories and applications of economics and basic understanding of business organizations and management. The Economics part covers three fundamental sections including Microeconomics, Macroeconomics and International Economics. The Business part covers functions and types of business and basic analytical tools. After one-year study of the course, students are expected to achieve the following goals: identify economics terms, understand economic theories and apply to real-life situations, draw economics diagrams to illustrate economic phenomenon, read and interpret economic data such as tables and graphs; understand function of business organizations; apply business analytical tools on real-life cases. Students will also have the opportunity to explore the most recent economic and business issues in the semester project. The course is offered at Standard level and Honors level. Standard level will have questions including multiple choices, theory interpretation and case studies, while Honors level will emphasize more on evaluation and application skills particularly on economics in the real world. The level will be decided after the first month of the first semester based on students' English level and first course test. Students should in English H, or have an equivalent TOEFL score of 100+ or an IELTS score of 7.5+. Students in Standard Level can move up to Honors level as long as they pass the move-up tests later after midterm or final exam. Homework expectations: 1-2 hours per week",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "current": [["MISSING: English 10 Honors"]] }
                }, { "id": "ECO110E170",
                    "name": "AP Microeconomics 10",
                    "track": "AP",
                    "description": "AP Microeconomics is a one-year precollege level course offered to students in grade 10 or 11. The purpose of AP Microeconomics is to give students a thorough understanding of the principles of economics that apply to the functions of individual decision makers, both consumers and producers, within the larger economic system. It places primary emphasis on the nature and functions of product markets, and includes the study of factor markets and the role of government in promoting greater efficiency and equity in the economy. It includes the following concepts: scarcity, opportunity costs and production possibilities, specialization and comparative advantage, the functions of any economic system, the nature and functions of product market, supply and demand, models of consumer choice, firm production, costs, revenues, product pricing and outputs, efficiency and government policy, factor markets, efficiency, equity, and the role of government. Homework Expectation: 3-4 hours of exercise on theories and analysis per week",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future."
                }
            ], "11": [
                {   "id": "ECO111E170",
                    "name": "AP Microeconomics 11",
                    "track": "AP",
                    "description": "AP Microeconomics is a one-year precollege level course offered to students in grade 10 or 11. The purpose of AP Microeconomics is to give students a thorough understanding of the principles of economics that apply to the functions of individual decision makers, both consumers and producers, within the larger economic system. It places primary emphasis on the nature and functions of product markets, and includes the study of factor markets and the role of government in promoting greater efficiency and equity in the economy. It includes the following concepts: scarcity, opportunity costs and production possibilities, specialization and comparative advantage, the functions of any economic system, the nature and functions of product market, supply and demand, models of consumer choice, firm production, costs, revenues, product pricing and outputs, efficiency and government policy, factor markets, efficiency, equity, and the role of government. Homework Expectation: 3-4 hours of exercise on theories and analysis per week",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future."
                }, { "id": "ECO111E171",
                    "name": "AP Macroeconomics 11",
                    "track": "AP",
                    "description": "AP Macroeconomics is a one-year pre-college level course offered to students in Grade 11/12. The purpose of AP Macroeconomics is to give students a thorough understanding of the principles of Economics that apply to an economic system as a whole. This course places emphasis on the study of national income and price-level determination, and also develops students' familiarity of economic performance measures, the financial sector stabilization policies, economic growth and international trade. Via this course, students are expected to gain progress on their critical thinking ability through making evaluations of the effectiveness of different government policies targeted at different Macroeconomics problems. The course should thus help students develop the skills necessary to present their reasons, analysis, synthesis and evidence clearly and persuasively and to arrive at their conclusions on the basis of such critical thinking. Homework Expectation: 3-4 hours of exercise on theories and analysis per week.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "pre": [["ECO110E170"]] }
                }, { "id": "ECO111E160",
                    "name": "IB Economics Y1",
                    "track": "IB",
                    "description": "IB Economics is a two-year course offered to IB students as a social study course. IB Economics year 1 is a one-year pre-college level course offered to students in grade 11 . The course emphasizes the studies of Microeconomics in the first semester; Macroeconomics and the first two topics of international trade in the second semester. As a first-year social science course in the IB diploma program, the course encourages students to explore the details of the principals of Microeconomics and Macroeconomics and to develop international perspectives, foster a concern for global issues, and raises students' awareness of their own responsibilities at a local, national and international level. The course is delivered at two levels, standard level and higher level. With the same syllabus, the students learning at the two levels study in the same classroom, mainly following the requirements for higher-level students. All the students have the same exam papers on the mid-term exam and the final exam. In the second semester, students are taught to write economic commentaries as required by the I B Economics syllabus. The commentary writing requirements for SL and HL students are the same. Two commentaries focusing Microeconomics and Macroeconomics respectively shall be finished by the end of the second semester. IB Economics year 2 is a one-year pre-college level course offered to students in grade 12. Based on the principles of Microeconomics and Macroeconomics, the second year course emphasizes the studies of international trade and development economics in the first semester and the review of the whole IB Economics syllabus for the May IB exam in the second semester. While the skills required for and the activities undertaken in studying Economics are similar for both SL and HL students, the HL students are required to acquire the abilities to analyze, synthesize and evaluate available information and to develop quantitative skills in order to evaluate and analyze economic relationships. Another commentary focusing on either international trade or development economics shall be finished before the end of the first semester. In the second semester, the SL and HL students will have different exam papers to better prepare themselves for the May IB Exam. Homework Expectation: 4-5 hours of exercise on theories and analysis per week.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": {
                        "pre": [["ECO110E130", "ECO110E170"]], 
                        "next": [["ECO112E160"]]
                    }
                }, { "id": "BUS111E140",
                    "name": "IB Business Management SL Y1",
                    "track": "IB",
                    "level": "SL",
                    "description": "IB Business Management is a two-year course offered to IB students as a social study course. The courses is delivered at standard level only. The course aims to develop transferable skills relevant to today's students. These include the ability to: think critically; make ethically sound and well-informed decisions; appreciate the pace, nature and significance of change; think strategically; and undertake long term planning, analysis and evaluation. The course also develops subject-specific skills, such as financial analysis. IB Business management year 1 is a one-year pre-college level course offered to students in grade 11 . The course emphasizes the studies of business organization and environment, Finance and accounts, and Marketing. As a first-year social science course in the I B diploma program, the course encourages students to explore the details of the theories of business management to develop their abilities to apply a range of tools and techniques as well as to analyze, discuss and evaluate business activities at local, national and international levels. IB Business management year 2 is a one-year pre-college level course offered to students in grade 12. The second year course emphasizes the studies of human resource and operation management in the first semester and the review of the whole IB Business management syllabus for the May IB exam in the second semester. The final draft of SL commentary shall be finished before the end of the first semester. Homework expectation: 4-5 hours of exercise on theories and analysis per week",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": {
                        "pre": [["ECO110E170", "ECO110E110", "ECO110E130"]], 
                        "next": [["BUS112E140"]]
                    }
                }, { "id": "ECO111E180",
                    "name": "A-Level Economics AS",
                    "track": "ASA2",
                    "level": "AS",
                    "description": "Oxford AQA A-Level Economics allows learners to explore concepts and theories which can be applied to the way that modern economies work. Learners develop the ability to explain, evaluate and analyse economic issues and arguments. It enables candidates to develop an understanding of the factual knowledge of economics. They gain lifelong skills and a solid foundation for further study. This course is a 2-year pre-college level course offered to students from Grade 11 with the first year teaching AS level and the second year teaching A level. Both of the levels will include the two main sections - Microeconomics and Macroeconomics. As the first year will deal with AS level, it will be easier than A2 level, aiming to give students a very basic understanding of economics. During this year, students will learn the basic economic ideas, the use of demand and supply to determine price and how government intervene the market. Most of the second semester of the first year will also be used for revision as students will take the AS level exam in May and June. The second year deals with A level, which is a more challenging level. Based on what students have learnt in AS level, the knowledge goes deeper and more complicated. At this level, more analytical and critical thinking abilities will be needed. Same as AS level, most of the second semester of this year will be used for revision. The A-level exam will involve 4 papers with AS level doing Paper 1 and 2 and A level doing Paper 3 and 4. The questions types vary from multiple choice questions, data response questions and essay questions. Homework expectation: 4-5 hours of practice every week",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "next": [["ECO112E180"]] }
                }, { "id": "ECO111E130",
                    "name": "Business Management 11",
                    "track": "school",
                    "level": "S",
                    "description": "Business management is a one year pre-college level course purposely designed for both grade 11 and grade 12 students. The teaching contents in Grade 11 are the same as the teaching contents in Grade 12 .Due to the impact of economic globalization and culture differences, we need to prepare our students to better understand the business structure, business functions, management styles, marketing strategies as well as cultural environment. To let our students better understand how the business organization functions, a variety of in-class activities, group discussions and cases studies would be conducted. It includes mock job interview, multi-stakeholders' interest debate, and contract/payment collection negotiation, etc. Every student is also encouraged to deliver high quality individual and group presentations as well. Fully understanding the main concept of the business environment is the key to the successful learning business management. Students should be quite familiar with the content of the textbook. Extensive reading in business related global news also helps students stay current in the fast-paced world. They should be well-informed about the outlook of global economy. Study resources are attached at the end of each chapter. We strongly encourage students to go through case studies after each lecture. After one year of study, students should be\n□ Able to understand the business structure, organizational culture, and business functions.\n □ Able to analyze the case studies related to the business world.\n □ Able to conduct market research on various business topics\n □ Able to rapport with your audience and present a business plan on a particular project.\n□ Able to make a commercial to target your consumers.\n Homework Expectation: home work will be assigned on a weekly basis, approximately 2-3 hours per week. Students are expected to hand in their assignments on time.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future."
                }, { "id": "LAW111E130",
                    "name": "Introduction to Law 11",
                    "track": "school",
                    "description": "This course, in the Fall semester, will begin with an introduction to legal concepts such as jurisdiction, burden of proof, evidence, etc. A focus on commercial/civil disputes and their settlement will follow to enhance the understanding of concept of law and reveal law's man-made and open-texture features. Students then will proceed to study some general principles of Contracts, Torts, and Agency, which can provide essential legal frameworks for advocacy and analysis. In the Spring semester, the course will begin with the study of logical reasoning and causation. Then it will further investigate causation in the sense of reasonableness and fairness by introducing detailed theories of Intentional Torts and Negligence. Case study and legal writing training will be conducted throughout the whole course to foster disciplined legal thinking skills. From time to time, mock trials and project presentations will be held where students would be expected to identify and argue about the points at issue from their assigned/chosen positions.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future."
                }, { "id": "SOC111E130",
                    "name": "Sociology 11 Standard",
                    "track": "school",
                    "level": "S",
                    "description": "Human life is inherently social, shaped by interactions with others. Over time, these interactions create patterns that become embedded in the structure of society. Sociology explores how society is formed and the dynamic connections between society and individuals. The discipline spans a wide range of topics, from family dynamics to online communities, from organized crime to religious practices, and from the divisions of race, gender, and social class to the shared beliefs of culture. This course introduces students to the foundational elements of sociology, including key concepts, theoretical perspectives, pressing social issues, and research methodologies. By adopting a sociological perspective, students will critically examine various social phenomena and develop a deeper understanding of the diverse, multicultural world. Through empirical research projects, this course aims to equip students with the skills to apply sociological insights to their daily lives. Designed as an introductory course, this course aims to introduce students to foundational sociological concepts, research areas, and methodologies. By acquiring basic sociological knowledge, students will enhance their capacity for critical reflection on societal issues, which can inform their future academic, professional, and personal decisions. It aims to spark interest in sociology and prepare students for advanced studies while fostering an understanding of individuals as social beings shaped by structural and cultural factors. Through hands-on projects, students will gain firsthand research experience and refine communication and analytical skills. Sociology's empirical approach helps students develop proficiency in using scientific data to understand complex social dynamics. It also connects students with real-world contexts, encouraging critical thinking and cultivating a deeper understanding of themselves and society. The course promotes self-recognition by exploring fundamental questions like: Who am I? Why am I who I am? How to position myself in the world? By emphasizing cultural diversity and holistic perspectives, it nurtures a compassionate and humanistic outlook.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future."
                }, { "id": "PSY111E100",
                    "name": "Psychology 11 Standard",
                    "track": "school",
                    "level": "S",
                    "description": "Psychology is a one-year course designed to help students understand the basic psychological concepts, theories, research and applications; to encourage students to explore and understand the relationship between psychological findings and everyday life; to develop skills of analysis, interpretation, application and evaluation. This course will cover topics such as cognitive psychology, social psychology, development psychology, educational psychology, abnormal psychology, methodology, psychological principles, empirical research, ethical inquiry, and real-world applications. The course supports students in developing psychological literacy — the capacity to understand, interpret, and apply psychological theory and evidence thoughtfully and ethically.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future."
                }, { "id": "PSY111E170",
                    "name": "AP Psychology 11",
                    "track": "AP",
                    "description": "The AP Psychology course offers a college-level introduction to the scientific study of behavior and mental processes in humans and other animals. It emphasizes core concepts, theoretical perspectives, and scientific reasoning skills central to psychology as a discipline. Students will explore major content areas through psychological principles, empirical research, ethical inquiry, and real-world applications. The redesigned AP Psychology framework is organized around five major units, each representing a foundational pillar of the discipline. Across the year students will engage with these themes while building essential science practices such as research design evaluation, quantitative data interpretation, concept application, and evidence-based argumentation.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "pre": [["MISSING: English 10 Honors"]] }
                }, { "id": "PSY111E140",
                    "name": "IB Psychology SL Y1",
                    "track": "IB",
                    "level": "SL",
                    "description": "In IB Psychology, students explore how behaviour and cognition are shaped by biological, cognitive and sociocultural factors through a concept-based approach. The course is organized around contexts (such as learning and cognition, health and well-being, and human development), content (key psychological theories and research), and six unifying concepts: causality, change, bias, perspective, measurement, and responsibility. Students learn how psychological knowledge is constructed by examining research methods, ethical considerations, and the strengths and limitations of evidence. IB Psychology SL emphasizes critical thinking, cultural awareness, and ethical responsibility. Students are encouraged to understand both shared human processes and cultural diversity in behaviour and cognition, fostering empathy and international-mindedness.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": {
                        "current": [["MISSING: English 11 Honors"]], 
                        "next": [["PSY112E140"]]
                    }
                }, { "id": "PSY111E140",
                    "name": "IB Psychology HL Y1",
                    "track": "IB",
                    "level": "HL",
                    "description": "IB Psychology HL adopts a concept-driven, inquiry-based approach, examining behaviour and cognition across biological, cognitive and sociocultural perspectives. The course is organized around contexts (such as learning and cognition, health and well-being, and human development), content (key psychological theories and research), and six unifying concepts: causality, change, bias, perspective, measurement, and responsibility. Students learn how psychological knowledge is constructed by examining research methods, ethical considerations, and the strengths and limitations of evidence. At Higher Level, students develop deeper analytical skills by engaging with additional research evidence, including the interpretation of statistical information. Ethical issues, methodological choices, and the evaluation of competing explanations are central to the course. The HL course promotes advanced critical thinking, intercultural understanding, and responsible application of psychological knowledge.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": {
                        "current": [["MISSING: English 11 Honors"]], 
                        "next": [["PSY112E140"]]
                    }
                }, { "id": "PSY111E180",
                    "name": "A-Level Psychology AS",
                    "track": "ASA2",
                    "level": "AS",
                    "description": "AQA A-Level Psychology explores interesting psychology topics in four units, considering both psychological theory and practical application. The first two units, to be completed in year 11, are at AS level, introducing basic knowledge of psychology and Biopsychology, development and research method 1. The last two units, to be completed in year 12, are at A2 level, including advanced topics and research method 2 as well as approaches and applications. During their course students will develop skills valued and expected by universities and employers, including critical analysis, independent thinking and scientific research. Students can sit unit exams in Jan or in May/June, and students can resit unit exams. The best unit exam results will count toward qualification grade.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "next": [["PSY112E180"]] }
                }
            ], "12": [
                {   "id": "ECO112E170",
                    "name": "AP Macroeconomics 12",
                    "track": "AP",
                    "description": "AP Macroeconomics is a one-year pre-college level course offered to students in Grade 11/12. The purpose of AP Macroeconomics is to give students a thorough understanding of the principles of Economics that apply to an economic system as a whole. This course places emphasis on the study of national income and price-level determination, and also develops students' familiarity of economic performance measures, the financial sector stabilization policies, economic growth and international trade. Via this course, students are expected to gain progress on their critical thinking ability through making evaluations of the effectiveness of different government policies targeted at different Macroeconomics problems. The course should thus help students develop the skills necessary to present their reasons, analysis, synthesis and evidence clearly and persuasively and to arrive at their conclusions on the basis of such critical thinking. Homework Expectation: 3-4 hours of exercise on theories and analysis per week.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future."
                }, { "id": "ECO112E160",
                    "name": "IB Economics Y2",
                    "track": "IB",
                    "description": "IB Economics is a two-year course offered to IB students as a social study course. IB Economics year 1 is a one-year pre-college level course offered to students in grade 11 . The course emphasizes the studies of Microeconomics in the first semester; Macroeconomics and the first two topics of international trade in the second semester. As a first-year social science course in the IB diploma program, the course encourages students to explore the details of the principals of Microeconomics and Macroeconomics and to develop international perspectives, foster a concern for global issues, and raises students' awareness of their own responsibilities at a local, national and international level. The course is delivered at two levels, standard level and higher level. With the same syllabus, the students learning at the two levels study in the same classroom, mainly following the requirements for higher-level students. All the students have the same exam papers on the mid-term exam and the final exam. In the second semester, students are taught to write economic commentaries as required by the I B Economics syllabus. The commentary writing requirements for SL and HL students are the same. Two commentaries focusing Microeconomics and Macroeconomics respectively shall be finished by the end of the second semester. IB Economics year 2 is a one-year pre-college level course offered to students in grade 12. Based on the principles of Microeconomics and Macroeconomics, the second year course emphasizes the studies of international trade and development economics in the first semester and the review of the whole IB Economics syllabus for the May IB exam in the second semester. While the skills required for and the activities undertaken in studying Economics are similar for both SL and HL students, the HL students are required to acquire the abilities to analyze, synthesize and evaluate available information and to develop quantitative skills in order to evaluate and analyze economic relationships. Another commentary focusing on either international trade or development economics shall be finished before the end of the first semester. In the second semester, the SL and HL students will have different exam papers to better prepare themselves for the May IB Exam. Homework Expectation: 4-5 hours of exercise on theories and analysis per week.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "pre": [["ECO111E160"]] }
                }, { "id": "BUS112E140",
                    "name": "IB Business Management SL Y2",
                    "track": "IB",
                    "level": "SL",
                    "description": "IB Business Management is a two-year course offered to IB students as a social study course. The courses is delivered at standard level only. The course aims to develop transferable skills relevant to today's students. These include the ability to: think critically; make ethically sound and well-informed decisions; appreciate the pace, nature and significance of change; think strategically; and undertake long term planning, analysis and evaluation. The course also develops subject-specific skills, such as financial analysis. IB Business management year 1 is a one-year pre-college level course offered to students in grade 11 . The course emphasizes the studies of business organization and environment, Finance and accounts, and Marketing. As a first-year social science course in the I B diploma program, the course encourages students to explore the details of the theories of business management to develop their abilities to apply a range of tools and techniques as well as to analyze, discuss and evaluate business activities at local, national and international levels. IB Business management year 2 is a one-year pre-college level course offered to students in grade 12. The second year course emphasizes the studies of human resource and operation management in the first semester and the review of the whole IB Business management syllabus for the May IB exam in the second semester. The final draft of SL commentary shall be finished before the end of the first semester. Homework expectation: 4-5 hours of exercise on theories and analysis per week",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "pre": [["BUS111E140"]] }
                }, { "id": "ECO112E180",
                    "name": "A-Level Economics A2",
                    "track": "ASA2",
                    "level": "A2",
                    "description": "Oxford AQA A-Level Economics allows learners to explore concepts and theories which can be applied to the way that modern economies work. Learners develop the ability to explain, evaluate and analyse economic issues and arguments. It enables candidates to develop an understanding of the factual knowledge of economics. They gain lifelong skills and a solid foundation for further study. This course is a 2-year pre-college level course offered to students from Grade 11 with the first year teaching AS level and the second year teaching A level. Both of the levels will include the two main sections - Microeconomics and Macroeconomics. As the first year will deal with AS level, it will be easier than A2 level, aiming to give students a very basic understanding of economics. During this year, students will learn the basic economic ideas, the use of demand and supply to determine price and how government intervene the market. Most of the second semester of the first year will also be used for revision as students will take the AS level exam in May and June. The second year deals with A level, which is a more challenging level. Based on what students have learnt in AS level, the knowledge goes deeper and more complicated. At this level, more analytical and critical thinking abilities will be needed. Same as AS level, most of the second semester of this year will be used for revision. The A-level exam will involve 4 papers with AS level doing Paper 1 and 2 and A level doing Paper 3 and 4. The questions types vary from multiple choice questions, data response questions and essay questions. Homework expectation: 4-5 hours of practice every week",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "pre": [["ECO111E180"]] }
                }, { "id": "ECO112E130",
                    "name": "Business Management 12",
                    "track": "school",
                    "level": "S",
                    "description": "Business management is a one year pre-college level course purposely designed for both grade 11 and grade 12 students. The teaching contents in Grade 11 are the same as the teaching contents in Grade 12 .Due to the impact of economic globalization and culture differences, we need to prepare our students to better understand the business structure, business functions, management styles, marketing strategies as well as cultural environment. To let our students better understand how the business organization functions, a variety of in-class activities, group discussions and cases studies would be conducted. It includes mock job interview, multi-stakeholders' interest debate, and contract/payment collection negotiation, etc. Every student is also encouraged to deliver high quality individual and group presentations as well. Fully understanding the main concept of the business environment is the key to the successful learning business management. Students should be quite familiar with the content of the textbook. Extensive reading in business related global news also helps students stay current in the fast-paced world. They should be well-informed about the outlook of global economy. Study resources are attached at the end of each chapter. We strongly encourage students to go through case studies after each lecture. After one year of study, students should be\n□ Able to understand the business structure, organizational culture, and business functions.\n □ Able to analyze the case studies related to the business world.\n □ Able to conduct market research on various business topics\n □ Able to rapport with your audience and present a business plan on a particular project.\n□ Able to make a commercial to target your consumers.\n Homework Expectation: home work will be assigned on a weekly basis, approximately 2-3 hours per week. Students are expected to hand in their assignments on time.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future."
                }, { "id": "ACC112E130",
                    "name": "Accounting 12 Standard",
                    "track": "school",
                    "level": "S",
                    "description": "The Accounting is a pre-college level course specially designed for 12th graders. The purpose of this course is to help our students understand the fundamental theories of financial accounting. The landscape of the business environment is changing at a fast pace and thus it is essential to better prepare our students for their rigorous college life and future career path. The world is round and that's why we are never able to see too far down the road. Our students may become top executives such as CEO, CFO, COO or may start up their own companies within a few years, and thus the first thing they need to know is to understand a company's financial statements. If they wish to work in a consulting firm, an investment banking group or a private equity firm after they graduate from the university, having accounting skills is essential to land decent jobs in those industries. The key to the successful learning accounting is through practicing exercises, working on problems and analyzing case studies. Study resources are attached at the end of each chapter. We strongly encourage students to go through every problem after each lecture. After one year of study, students are expected □ To understand and analyze real life situations by applying US GAAP: Generally Accepted Accounting Principles.\n □ To conduct a full cycle accounting by following the US GAAP.\n □ To be able to post daily journal entries, prepare a general ledger and financial statements including the balance sheet, income statement, cash flow statement and statement of stockholders' equity.\n□ To prepare financial statements and analyze financial information o f companies from different industries at the end of the school year.\n Homework: home work will be assigned on a weekly basis, approximately 2-3 hours per week. Students are expected to hand in their assignments on time.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "current": [["MISSING: English 12 Honors"]] }
                }, { "id": "LAW112E130",
                    "name": "Introduction to Law 12",
                    "track": "school",
                    "description": "This course, in the Fall semester, will begin with an introduction to legal concepts such as jurisdiction, burden of proof, evidence, etc. A focus on commercial/civil disputes and their settlement will follow to enhance the understanding of concept of law and reveal law's man-made and open-texture features. Students then will proceed to study some general principles of Contracts, Torts, and Agency, which can provide essential legal frameworks for advocacy and analysis. In the Spring semester, the course will begin with the study of logical reasoning and causation. Then it will further investigate causation in the sense of reasonableness and fairness by introducing detailed theories of Intentional Torts and Negligence. Case study and legal writing training will be conducted throughout the whole course to foster disciplined legal thinking skills. From time to time, mock trials and project presentations will be held where students would be expected to identify and argue about the points at issue from their assigned/chosen positions.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future."
                }, { "id": "SOC112E130",
                    "name": "Sociology 12 Standard",
                    "track": "school",
                    "level": "S",
                    "description": "Human life is inherently social, shaped by interactions with others. Over time, these interactions create patterns that become embedded in the structure of society. Sociology explores how society is formed and the dynamic connections between society and individuals. The discipline spans a wide range of topics, from family dynamics to online communities, from organized crime to religious practices, and from the divisions of race, gender, and social class to the shared beliefs of culture. This course introduces students to the foundational elements of sociology, including key concepts, theoretical perspectives, pressing social issues, and research methodologies. By adopting a sociological perspective, students will critically examine various social phenomena and develop a deeper understanding of the diverse, multicultural world. Through empirical research projects, this course aims to equip students with the skills to apply sociological insights to their daily lives. Designed as an introductory course, this course aims to introduce students to foundational sociological concepts, research areas, and methodologies. By acquiring basic sociological knowledge, students will enhance their capacity for critical reflection on societal issues, which can inform their future academic, professional, and personal decisions. It aims to spark interest in sociology and prepare students for advanced studies while fostering an understanding of individuals as social beings shaped by structural and cultural factors. Through hands-on projects, students will gain firsthand research experience and refine communication and analytical skills. Sociology's empirical approach helps students develop proficiency in using scientific data to understand complex social dynamics. It also connects students with real-world contexts, encouraging critical thinking and cultivating a deeper understanding of themselves and society. The course promotes self-recognition by exploring fundamental questions like: Who am I? Why am I who I am? How to position myself in the world? By emphasizing cultural diversity and holistic perspectives, it nurtures a compassionate and humanistic outlook.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future."
                }, { "name": "AP Business with Personal Finance 12",
                    "track": "AP",
                    "description": "AP Business with Personal Finance is a yearlong course that integrates college-level introductory business knowledge with essential personal financial literacy. Aligned with US national standards for personal financial education, the course equips students with workforce-ready skills through real-world applications, case studies, and project-based learning. The curriculum is structured into five core units: Businesses, Competition, and New Ideas; Marketing; Personal Saving, Borrowing, and Business Finance/Accounting; Management and Strategy; and Personal Goals, Budgeting, and Investing. Throughout the course, students complete two pivotal projects: the Business Canvas Project, where they develop an entrepreneurial plan encompassing product development, market research, a n d financial documentation; and the Financial Advisor Project, which requires providing tailored financial recommendations to a fictional household for goals like post-secondary education, homebuying, and retirement planning. Assessment is conducted via a fully digital exam administered in May through the Bluebook platform. The exam consists of two sections: Multiple Choice questions testing knowledge and application of core concepts; and Free Response questions that require analysis of realistic business scenarios, including one focused on the execution of the student's Business Canvas Project. The course's major objectives are to foster students' business and professional skills: explaining business and personal finance principles, interpreting quantitative and qualitative data, identifying market opportunities for entrepreneurship, and making evidence-based decisions. It also aims to develop leadership, communication, and collaborative abilities through project work. Ultimately, the course prepares students for diverse careers in business and equips them with the knowledge to make informed personal financial decisions, fulfilling national personal financial education standards.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future."
                }, { "id": "PSY112E100",
                    "name": "Psychology 12 Standard",
                    "track": "school",
                    "level": "S",
                    "description": "Psychology is a one-year course designed to help students understand the basic psychological concepts, theories, research and applications; to encourage students to explore and understand the relationship between psychological findings and everyday life; to develop skills of analysis, interpretation, application and evaluation. This course will cover topics such as cognitive psychology, social psychology, development psychology, educational psychology, abnormal psychology, methodology, psychological principles, empirical research, ethical inquiry, and real-world applications. The course supports students in developing psychological literacy — the capacity to understand, interpret, and apply psychological theory and evidence thoughtfully and ethically.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "pre": [["MISSING: everything EXCEPT AP Psychology in G11"]] }
                }, { "id": "PSY112E170",
                    "name": "AP Psychology 12",
                    "track": "AP",
                    "description": "The AP Psychology course offers a college-level introduction to the scientific study of behavior and mental processes in humans and other animals. It emphasizes core concepts, theoretical perspectives, and scientific reasoning skills central to psychology as a discipline. Students will explore major content areas through psychological principles, empirical research, ethical inquiry, and real-world applications. The redesigned AP Psychology framework is organized around five major units, each representing a foundational pillar of the discipline. Across the year students will engage with these themes while building essential science practices such as research design evaluation, quantitative data interpretation, concept application, and evidence-based argumentation.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future."
                }, { "id": "PSY112E140",
                    "name": "IB Psychology SL Y2",
                    "track": "IB",
                    "level": "SL",
                    "description": "In IB Psychology, students explore how behaviour and cognition are shaped by biological, cognitive and sociocultural factors through a concept-based approach. The course is organized around contexts (such as learning and cognition, health and well-being, and human development), content (key psychological theories and research), and six unifying concepts: causality, change, bias, perspective, measurement, and responsibility. Students learn how psychological knowledge is constructed by examining research methods, ethical considerations, and the strengths and limitations of evidence. IB Psychology SL emphasizes critical thinking, cultural awareness, and ethical responsibility. Students are encouraged to understand both shared human processes and cultural diversity in behaviour and cognition, fostering empathy and international-mindedness.",
                    "crowdRating": 6.7,
