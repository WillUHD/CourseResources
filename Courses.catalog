        }, "chemistry": {
            "9": [
                {   "id": "CHE009E010",
                    "name": "Chemistry 9 Standard",
                    "track": "school",
                    "level": "S",
                    "description": "Chemistry is an experimental science concerned with the search for and acquisition of knowledge about the fundamental nature and characteristics of the matter of which the universe is composed. Grade 9 chemistry introduces the composition and structure of matter and the changes that matter undergo. It is designed to stimulate the students' interest in science and give them an insight into the nature of chemistry. This course expands on topics introduced in the textbook and introduces topics needed for further study of chemistry and other experimental courses. Topics of study mainly include: scientific method, classification of matter, periodic table and trend, atomic theories and models, properties of elements ionor bonds basic experimental operation method. Students are expected to finish 5~6 experiments throughout the year. Students should have a knowledge of basic chemical terminology, facts, principles and methods. They should be able to perform experiments safely and co-operatively.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future."
                }, { "id": "CHE009E020",
                    "name": "Chemistry 9 S+",
                    "track": "school",
                    "level": "S+",
                    "description": "Chemistry is an experimental science concerned with the search for and acquisition of knowledge about the fundamental nature and characteristics of the matter of which the universe is composed. Grade 9 chemistry introduces the composition and structure of matter and the changes that matter undergo. It is designed to stimulate the students' interest in science and give them an insight into the nature of chemistry. This course expands on topics introduced in the textbook and introduces topics needed for further study of chemistry and other experimental courses. Topics of study mainly include: scientific method, classification of matter, periodic table and trend, atomic theories and models, basic nomenclature method, chemical reactions, ionor , basic experimental operation method. Students are expected to finish 5~6 experiments throughout the year. Based on the basic chemistry facts and principles, students should understand how chemistry relates to everyday life, scientific information in verbal, graphical and mathematical form, basic chemical principles, how chemical problems can be solved.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future."
                }, { "id": "CHE009E030",
                    "name": "Chemistry 9 Honors",
                    "track": "school",
                    "level": "H",
                    "description": "Chemistry is an experimental science concerned with the search for and acquisition of knowledge about the fundamental nature and characteristics of the matter of which the universe is composed. Grade 9 chemistry introduces the composition and structure of matter and the changes that matter undergo. It is designed to stimulate the students' interest in science and give them an insight into the nature of chemistry.It's a preparation for future chemistry courses. This course expands on topics introduced in textbook and introduces topics needed for further study of chemistry and other experimental courses. Topics of study mainly include: scientific method, classification of matter, periodic table properties for representation elements, atomic theories and models, basic nomenclature method, chemical reactions, ionor bonds, basic experimental operation method. basic rules for writing report data analysis measurement and error analysis ,Students are expected to finish 5~6 experiments throughout the year. Based on the basic chemistry facts and principles, students should begin to realize how the scientific method applies to chemistry. They are expected to acquire social, historical, environmental, technological and economic aspects of chemistry. They should be able to perform simple chemical calculations related to chemical reaction and make accurate observations and measurements to collect experimental data and assess the accuracy of experimental results.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future."
                }
            ], "10": [
                {   "id": "CHE010E010",
                    "name": "Chemistry 10 Standard",
                    "track": "school",
                    "level": "S",
                    "description": "This course expands on topics introduced in textbook and introduces topics needed for further study of chemistry and other experimental courses. It is designed to stimulate the students' interest in science and give them an insight into the nature of chemistry. Topics of study mainly include: covalent bonds chemical reactions, moles, stoichiometry, states of matter, intermolecular forces and solutions. Students are expected to finish 4~6 experiments throughout the year. Students should have a knowledge of basic chemical terminology, facts, principles and methods. They should be able to use mathematics properly to solve for some simple chemistry problems and be able to perform experiments safely and co-operatively.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "pre": [["CHE009E010"]] }
                }, { "id": "CHE010E030",
                    "name": "Chemistry 10 Honors",
                    "track": "school",
                    "level": "H",
                    "description": "This course expands on topics introduced in textbook and introduces topics needed for further study of chemistry and other experimental courses. It is designed to stimulate the students' interest in science and give them an insight into the nature of chemistry. Topics of study mainly include: chemical reactions, moles, stoichiometry, states of matter, intermolecular forces and solutions. The honors level is equivalent to pre-IB and pre-AP chemistry course. Students are expected to finish 4~6 experiments throughout the year. Students should know how to apply and analyze the use chemistry facts, concepts, methods and scientific explanation. They should be able to use mathematics properly to solve for some chemistry problems. They are expected to construct research questions, to collect experimental data and evaluate the results and some scientific explanations. Students of this level are also encouraged to take the AP chemistry pretest.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "pre": [["CHE009E030"]] }
                }
            ], "11": [
                {   "id": "CHE011E010",
                    "name": "Chemistry 11 Standard",
                    "track": "school",
                    "level": "S",
                    "description": "From the grade 11 it talks about every aspect very detail in chemistry. The contents of this course include solutions, thermo chemistry, reaction rates &equilibrium, acids, bases and salts, redox reactions, electrochemistry, hydrocarbon compounds, and functional groups. In recognition that all students are expected to take the SAT II Chemistry Test, course content, laboratory activities, textbook assignments, activities and projects will all be carried through with the skills and content required to be successful on the standardized test.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "pre": [["CHE010E010"]] }
                }, { "id": "CHE011E030",
                    "name": "Chemistry 11 Honors",
                    "track": "school",
                    "level": "H",
                    "description": "From the grade 11 it talks about every aspect very detail in chemistry. The contents of this course include reaction rates, chemical equilibrium, acids &bases, redox reactions, electrochemistry, hydrocarbons, substituted hydrocarbons &their reactions, and the chemistry of life. In recognition that all students are expected to take the SAT II Chemistry Test, course content, laboratory activities, textbook assignments, activities and projects will all be carried through with the skills and content required to be successful on the standardized test.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "pre": [["CHE010E030"]] }
                }, { "id": "CHE011E070",
                    "name": "AP Chemistry 11",
                    "track": "AP",
                    "description": "The AP Chemistry course provides students with a foundation to support future advanced course work in chemistry. Through inquiry based learning, students develop critical thinking and reasoning skills. Students cultivate their understanding of chemistry and science practices as they explore topics such as: atomic structure, intermolecular forces and bonding, chemical reactions, kinetics, thermodynamics, and equilibrium. This course requires that 25 percent of the instructional time provides students with opportunities to engage in laboratory investigations. This includes a minimum of 16 hands-on labs, at least six of which are inquiry based. The key concepts and related content that define the AP Chemistry course and exam are organized around underlying principles called the Big Ideas. They encompass core scientific principles, theories, and processes that cut across traditional boundaries and provide a broad way of thinking about the particulate nature of matter underlying the observations students make about the physical world. The following are Big Ideas: The chemical elements are the building blocks of matter, which can be understood in terms of the arrangements of atoms. Chemical and physical properties of materials can be explained by the structure and the arrangement of atoms, ions, or molecules and the forces between them. Changes in matter involve the rearrangement and/or reorganization of atoms and/or the transfer of electrons. Rates of chemical reactions are determined by details of the molecular collisions. The laws of thermodynamics describe the essential role of energy and explain and predict the direction of changes in matter. Bonds or attractions that can be formed can be broken. These two processes are in constant competition, sensitive to initial conditions and external forces or changes.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": {
                        "pre": [["CHE010E030"]],
                        "current": [["MISSING: ENG 11S+"]]
                    }
                }, { "id": "CHE011E040",
                    "name": "IB Chemistry SL Y1",
                    "track": "IB",
                    "level": "SL",
                    "description": "The Diploma Program chemistry course includes the essential principles of the subject but also, through selection of an option, allows teachers some flexibility to tailor the course to meet the needs of their students. At the school level both theory and experiments should be undertaken by all students. They should complement one another naturally, as they do in the wider scientific community. The Diploma Program chemistry course allows students to develop traditional practical skills and techniques and to increase facility in the use of mathematics, which is the language of science. It also allows students to develop interpersonal skills, and digital technology skills, which are essential in 21st century scientific endeavour an dare important life-enhancing, transferable skills in their own right. Students at standard level (SL) and higher level (HL) undertake a common core syllabus, a common internal assessment (IA) scheme and have some overlapping elements in the option studied. They are presented with a syllabus that encourages the development of certain skills, attributes and attitudes, as described in the \"Assessment objectives\" section of this guide. While the skills and activities of group 4 science subjects are common to students at both SL and HL, students at HL are required to study some topics in greater depth, in the additional higher level (AHL) material and in the common options. The distinction between SL and HL is one of breadth and depth. Core and additional components: stoichiometric relationships, atomic structure, periodicity, chemical bonding and structure, energetics/thermochemistry, chemical kinetics, equilibrium, acids and bases, redox processes, organic chemistry, measurement and analysis, data processing. Optional components: materials, biochemistry, energy, medical chemistry",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": {
                        "pre": [["CHE010E030"]],
                        "current": [["MISSING: ENG 11S+"]],
                        "next": [["CHE012E040"]]
                    }
                }, { "id": "CHE011E050",
                    "name": "IB Chemistry HL Y1",
                    "track": "IB",
                    "level": "HL",
                    "description": "The Diploma Program chemistry course includes the essential principles of the subject but also, through selection of an option, allows teachers some flexibility to tailor the course to meet the needs of their students. At the school level both theory and experiments should be undertaken by all students. They should complement one another naturally, as they do in the wider scientific community. The Diploma Program chemistry course allows students to develop traditional practical skills and techniques and to increase facility in the use of mathematics, which is the language of science. It also allows students to develop interpersonal skills, and digital technology skills, which are essential in 21st century scientific endeavour an dare important life-enhancing, transferable skills in their own right. Students at standard level (SL) and higher level (HL) undertake a common core syllabus, a common internal assessment (IA) scheme and have some overlapping elements in the option studied. They are presented with a syllabus that encourages the development of certain skills, attributes and attitudes, as described in the \"Assessment objectives\" section of this guide. While the skills and activities of group 4 science subjects are common to students at both SL and HL, students at HL are required to study some topics in greater depth, in the additional higher level (AHL) material and in the common options. The distinction between SL and HL is one of breadth and depth. Core and additional components: stoichiometric relationships, atomic structure, periodicity, chemical bonding and structure, energetics/thermochemistry, chemical kinetics, equilibrium, acids and bases, redox processes, organic chemistry, measurement and analysis, data processing. Optional components: materials, biochemistry, energy, medical chemistry",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": {
                        "pre": [["CHE010E030"]],
                        "current": [["MISSING: ENG 11S+"]],
                        "next": [["CHE012E050"]]
                    }
                }, { "id": "CHE011E180",
                    "name": "A-Level Chemistry AS",
                    "track": "ASA2",
                    "level": "AS",
                    "description": "This is a college-level course designed to help students who intend to take AS-level chemistry qualifications in 11th grade. The full International A-Level is intended to be taken over two years. Students can take the International AS in the first year at the end of the course. Core contents in AS-level Chemistry cover themes including physical chemistry, inorganic chemistry and organic chemistry. The contents in physical chemistry include \"Atomic structure\", \"Amount of substance\", \"Bonding\", \"Energetic\", \"Kinetics\", \"Chemical equilibria, Le Chatelier's Principle and Kc\", \"Oxidation, reduction and redox equations\"; the contents in inorganic chemistry include \"Periodicity\", \"Group 2, the alkaline earth metals\", \"Group 7(17), the halogens\"; the contents in organic chemistry include \"Introduction to organic chemistry\", \"Alkanes\", \"Halogenoalkanes\", \"Alkenes\", \"Alcohols\", \"Organic analysis\". Except for core contents, practical skills are also required for AS-level candidates. Students must carry out the practical activities including making volumetric solution, carrying out acid-base titration, measuring an enthalpy change, carrying out simple test-tube reactions to identify ions, distilling a product from a reaction, carrying out tests for alcohols, aldehydes, alkenes and carboxylic acids. After learning this course, the students are expected to have learnt to go into the subject in considerable depth and practice the lab skills necessary for further study in university.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": {
                        "pre": [["CHE010E010", "CHE010E030"]],
                        "next": [["CHE012E180"]]
                    }
                }
            ], "12": [
                {   "id": "CHE012E110",
                    "name": "Chemistry 12 Standard",
                    "track": "school",
                    "level": "S",
                    "description": "The Grade 12 Chemistry standard level class is designed for ordinary students to fulfill the Chemistry course in senior high school. In Grade 12, Students will learn about oxidation-reduction reaction,electrochemistry, organic chemistry, biochemistry, and nuclear chemistry, and how they play a major role in your daily life. They will also learn about the utilization of nuclear reactions for medicine, science, and energy production, carbon-containing organic compounds, reactions of carbon with other elements, and the wide spread of carbon compounds in plants and animals. Each student should build up a global perspective by reporting science news. At the end of year, students will have a complete knowledge of the central science chemistry and pursue future studying with methodology and core scientific literacy learned in the course.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "pre": [["CHE011E010"]] }
                }, { "id": "CHE012E130",
                    "name": "Chemistry 12 Honors",
                    "track": "school",
                    "level": "H",
                    "description": "The Grade 12 Chemistry Honors level class is designed for competent students to fulfill the Chemistry course in senior high school. The H level class will discuss some part of knowledge in greater depth and also grant students more opportunity to go to lab. The 12th Grade H chemistry covers the Electrochemistry, Organic Chemistry, Biochemistry, Nuclear Chemistry,and Environmental Chemistry. The Grade 12 H level chemistry aims to teach students understand the essence of the reaction, the nature of chemistry, and the nature of science briefly,and apply what they have learned to the world through a weekly news reporting and a monthly STSE (Science, Technology, Society, and Environment) presentation.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "pre": [["CHE011E030"]] }
                }, { "id": "CHE012E070",
                    "name": "AP Chemistry 12",
                    "track": "AP",
                    "description": "The AP Chemistry course provides students with a foundation to support future advanced course work in chemistry. Through inquiry based learning, students develop critical thinking and reasoning skills. Students cultivate their understanding of chemistry and science practices as they explore topics such as: atomic structure, intermolecular forces and bonding, chemical reactions, kinetics, thermodynamics, and equilibrium. This course requires that 25 percent of the instructional time provides students with opportunities to engage in laboratory investigations. This includes a minimum of 16 hands-on labs, at least six of which are inquiry based. The key concepts and related content that define the AP Chemistry course and exam are organized around underlying principles called the Big Ideas. They encompass core scientific principles, theories, and processes that cut across traditional boundaries and provide a broad way of thinking about the particulate nature of matter underlying the observations students make about the physical world. The following are Big Ideas: The chemical elements are the building blocks of matter, which can be understood in terms of the arrangements of atoms. Chemical and physical properties of materials can be explained by the structure and the arrangement of atoms, ions, or molecules and the forces between them. Changes in matter involve the rearrangement and/or reorganization of atoms and/or the transfer of electrons. Rates of chemical reactions are determined by details of the molecular collisions. The laws of thermodynamics describe the essential role of energy and explain and predict the direction of changes in matter. Bonds or attractions that can be formed can be broken. These two processes are in constant competition, sensitive to initial conditions and external forces or changes.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": {
                        "pre": [["MISSING: G11 AP SCIENCE", "CHE011E070"]],
                        "current": [["MISSING: ENG 12S+"]]
                    }
                }, { "id": "CHE012E040",
                    "name": "IB Chemistry SL Y2",
                    "track": "IB",
                    "level": "SL",
                    "description": "The Diploma Program chemistry course includes the essential principles of the subject but also, through selection of an option, allows teachers some flexibility to tailor the course to meet the needs of their students. At the school level both theory and experiments should be undertaken by all students. They should complement one another naturally, as they do in the wider scientific community. The Diploma Program chemistry course allows students to develop traditional practical skills and techniques and to increase facility in the use of mathematics, which is the language of science. It also allows students to develop interpersonal skills, and digital technology skills, which are essential in 21st century scientific endeavour an dare important life-enhancing, transferable skills in their own right. Students at standard level (SL) and higher level (HL) undertake a common core syllabus, a common internal assessment (IA) scheme and have some overlapping elements in the option studied. They are presented with a syllabus that encourages the development of certain skills, attributes and attitudes, as described in the \"Assessment objectives\" section of this guide. While the skills and activities of group 4 science subjects are common to students at both SL and HL, students at HL are required to study some topics in greater depth, in the additional higher level (AHL) material and in the common options. The distinction between SL and HL is one of breadth and depth. Core and additional components: stoichiometric relationships, atomic structure, periodicity, chemical bonding and structure, energetics/thermochemistry, chemical kinetics, equilibrium, acids and bases, redox processes, organic chemistry, measurement and analysis, data processing. Optional components: materials, biochemistry, energy, medical chemistry",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": {
                        "pre": [["CHE011E040"]],
                        "current": [["MISSING: ENG 12S+"]]
                    }
                }, { "id": "CHE012E050",
                    "name": "IB Chemistry HL Y2",
                    "track": "IB",
                    "level": "HL",
                    "description": "The Diploma Program chemistry course includes the essential principles of the subject but also, through selection of an option, allows teachers some flexibility to tailor the course to meet the needs of their students. At the school level both theory and experiments should be undertaken by all students. They should complement one another naturally, as they do in the wider scientific community. The Diploma Program chemistry course allows students to develop traditional practical skills and techniques and to increase facility in the use of mathematics, which is the language of science. It also allows students to develop interpersonal skills, and digital technology skills, which are essential in 21st century scientific endeavour an dare important life-enhancing, transferable skills in their own right. Students at standard level (SL) and higher level (HL) undertake a common core syllabus, a common internal assessment (IA) scheme and have some overlapping elements in the option studied. They are presented with a syllabus that encourages the development of certain skills, attributes and attitudes, as described in the \"Assessment objectives\" section of this guide. While the skills and activities of group 4 science subjects are common to students at both SL and HL, students at HL are required to study some topics in greater depth, in the additional higher level (AHL) material and in the common options. The distinction between SL and HL is one of breadth and depth. Core and additional components: stoichiometric relationships, atomic structure, periodicity, chemical bonding and structure, energetics/thermochemistry, chemical kinetics, equilibrium, acids and bases, redox processes, organic chemistry, measurement and analysis, data processing. Optional components: materials, biochemistry, energy, medical chemistry",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": {
                        "pre": [["CHE011E050"]],
                        "current": [["MISSING: ENG 12S+"]]
                    }
                }, { "id": "CHE012E180",
                    "name": "A-Level Chemistry A2",
                    "track": "ASA2",
                    "level": "A2",
                    "description": "This is a college-level course designed to help students who intend to take A2-level chemistry qualifications in 12th grade. The full International A-level is intended to be taken over two years. Students can take the International AS in the first year at the end of the course. Core contents in A2-level Chemistry cover themes including physical chemistry, inorganic chemistry and organic chemistry. The contents in physical chemistry include \"Thermodynamics\", \"Rate equations\", \"Equilibrium constant Kp for homogeneous systems\", \"Electrode potentials and electrochemical cells\", \"Acid and bases\"; the contents in inorganic chemistry include \"Properties of period 3 elements and their oxides and chlorides\", \"Transition metals\", \"Reactions of ions in aqueous solution\"; the contents in organic chemistry include \"Optical isomerism\", \"Aldehydes and ketons\", \"Carboxylic acids and derivatives\", \"Aromatic chemistry\", \"Amines\", \"Polymers\", \"Amino acids and proteins\", \"Organic synthesis\", \"Nuclear magnetic resonance spectroscopy\", \"Chromatography\". The International A2 written papers test knowledge and understanding of the procedures involved and require an evaluation of the techniques adopted. Students must carry out the practical activities including measuring the rate of reaction by an initial rate method and a continuous 16(EMF) of an electrochemical cell, investigating how pH change during acid-base reaction, carrying out simple test-tube reactions to identify transition metal ions in aqueous solution, preparing a pure organic solid and test its purity. After learning this course, the students are expected to have learnt to go into the subject in considerable depth and practice the lab skills necessary for further study in university.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "pre": [["CHE011E180"]] }
                }, { "id": "CHE012E120",
                    "name": "Organic Chemistry 12",
                    "track": "school",
                    "description": "This course is a fundamental course in organic chemistry based upon the modern concepts of structure and mechanism of reactions. Topics of study mainly include: 1) bonding and structures of organic molecules; 2) the concepts of nomenclature, isomerism, and reaction mechanism; 3) the relationship between structure and reactivity of organic functional groups; 4) study of important types of reactions, with emphasis on synthetic usefulness and mechanisms; 5) the theoretical basis and applications of modern spectroscopic methods such as Infrared, mass spectroscopy and nuclear magnetic resonance spectroscopy; 6) exploring biologically important organic molecules such as carbohydrates, proteins, lipids, and nucleic acids. Additionally, this course involves conducting experiments in which both the theoretical and practical aspects of a variety of organic reactions are emphasized. Modern chromatographic, instrumental, and spectroscopic techniques are applied to these investigations and experiments.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "pre": [["CHE011E070"]] }
                }
            ]
        }, "chinese": {
            "9": [
                {   "id": "CHI009E001",
                    "name": "Chinese Level 1 9 Y1",
                    "track": "school",
                    "description": "This course is designed for non-native Chinese speakers in SHSID high school, who are beginners in learning Chinese. Texts and exercises include short dialogues, short passages, and simple written language exercises. The content mainly focuses on overseas students’ life and their study in China. Students are required to master Chinese pinyin, simple Chinese characters and basic communication skills in their daily life and study.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "next": [["CHI010E001"]] }
                }, { "id": "CHI009E002",
                    "name": "Chinese Level 2 9 Y1",
                    "track": "school",
                    "description": "This course is designed for elementary non-native Chinese learners in SHSID high school. Students are exposed to various situations to practice their communication skills. With short conversations and passages, the text helps students to accumulate comprehensive language skills, especially communication skills that are slightly complicate in their daily life and overseas study in both oral and simple written language.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "next": [["CHI010E002"]] }
                }, { "id": "CHI009E003",
                    "name": "Chinese Level 3 9 Y1",
                    "track": "school",
                    "description": "This course is designed for SHSID high school students who had already finished 500 hours of Chinese Non-native Chinese course (or equivalent of this level). This course aims to train students to communicate in Chinese with the topics learned in the texts. It also helps students to improve the writing ability. Students are supposed to write essays with the topics learned in the texts with a word limit 250.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "next": [["CHI010E003"]] }
                }, { "id": "CHI009E004",
                    "name": "Chinese Level 4 9 Y1",
                    "track": "school",
                    "description": "This course is designed for SHSID high school non-native Chinese speakers who have accomplished 600 periods of Chinese study (or equivalent to this level) and have commanded basic grammar and lexical knowledge and communication skills. The content mainly focuses on popular worldwide topics. It aims to standardize the students’ habits of using Chinese. On basis of what they have learned in previous courses, students will delve deeper to master more complicated sentence structures, and polish their expressions for common words and develop to write longer paragraphs. In the meanwhile, their understanding of the Chinese culture will be deepened.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "next": [["CHI010E004"]] }
                }, { "id": "CHI009E005",
                    "name": "Chinese Level 5 9 Y1",
                    "track": "school",
                    "description": "This course is designed for high school students who had already finished 800 hours of non-native Chinese language course. This course aims to train students to understand and use complicated grammars. Students are required to memorize over 2000 new words and able to use more than 100 grammar regulations in a precise way. In the meanwhile, they will be familiar with topics of modern Chinese society and traditional culture in this course. They are expected to be able to write essays of over 300 words in this course.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "next": [["CHI010E005"]] }
                }, { "id": "CHI009E006",
                    "name": "Chinese Level 6 9 Y1",
                    "track": "school",
                    "description": "This course is designed for high school students who had already finished 1000 hours of non-native Chinese language course. In this course, students are required to understand longer and complicate Chinese articles. They will learn how to read news articles and write comments on the article. Also, they will have a profound knowledge about Chinese culture and traditions in this course. They should be able to write essays with over 400 words after finishing this course.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "next": [["CHI010E006", "CHI010E170"]] }
                }, { "id": "CHI009E110",
                    "name": "Chinese Level 8 9 (S)",
                    "track": "school",
                    "level": "S",
                    "description": "This course primarily aims to assist students in mastering the fundamentals of Chinese characters, vocabulary, and grammar, different narrative techniques used interchangeably; reasoning by material, classification and comparison talk methods. providing a foundation for training in both written and oral expression. It serves as a preparatory course for choosing the IB Chinese B HL program.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "next": [["CHI010E110"]] }
                }, { "id": "CHI009E120",
                    "name": "Chinese Level 9 9 (H)",
                    "track": "school",
                    "level": "H",
                    "description": "The course is designed to enable students to master several descriptions of the relevant figures; different approaches for description of the scene, such as subjective description and objective description of positive description and side contrast; contrast narrative lyric; different narrative techniques used interchangeably; reasoning by material, classification and comparison talk methods. Students will also learn the classical literature and poetry. They are required to grasp basic skills of reading classical Chinese literature texts. It serves as a preparatory course for choosing the IB Chinese A language program.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "next": [["CHI010E120", "CHI010E130"]] }
                }, { "id": "CHI009E130",
                    "name": "Chinese Level 10 9 (H+)",
                    "track": "school",
                    "level": "H+",
                    "description": "Chinese Level X is an advanced literature course designed for students who have demonstrated strong proficiency in Chinese and a keen interest in literary studies. The course aims to deepen students' engagement with Chinese literature while enhancing their analytical and critical thinking skills. Through Level X, students will: Explore a wide range of literary genres and works. Develop refined close-reading and textual analysis abilities. Begin training in literary essay writing, learning to articulate independent viewpoints. Encounter a higher level of challenge in both reading volume and intellectual depth compared to Level IX. The course is particularly suited for high-achieving Level IX students who are passionate about literature and may consider pursuing IB Chinese Language A in the future. It serves as an excellent preparatory pathway, helping students adapt to the demands of IB-level literary study.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "next": [["CHI010E130"]] }
                }
