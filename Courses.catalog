                        "next": [["GEO110E130"]]
                    }
                }
            ], "10": [
                {   "id": "GEO110E110",
                    "name": "Human Geography 10 Standard",
                    "track": "school",
                    "level": "S",
                    "description": "Though culture is a central, complex concept in geography, it may be thought of as a way of life involving a particular set of skills, values and meanings. This course introduces cultural products and norms and their variations across and relations to spaces and places. It focuses on describing and analyzing the ways language, religion, ethnicity, government and other cultural phenomena vary or remain constant, from one place to another and on explaining how humans function spatially. Students at this level need to understand basic concepts and start to interpret social phenomena using geographic skilled taught in class. Students will take map tests, chapter tests, exams and class participation.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "next": [["GEO111E110"]] }
                }, { "id": "GEO110E130",
                    "name": "Human Geography 10 Honors",
                    "track": "school",
                    "level": "H",
                    "description": "This course centers its attention on spatial variations among cultural groups and the special functioning of society, and the changing and multifaceted relationships between people and the environments in which they reside. Students will learn cultural concepts and theories needed to understand the complexity of spaces. Like other fields of contemporary life, culture has been profoundly affected by globalization. The course provides knowledge of the interdependence of places and regions in globalizing world, and the major changes that have taken place in global, regional, and local landscapes. Students at this level should develop capability of critical thinking by raising, discussing and answering their own questions. The acquisition of skills related to this course and its learning outcomes will be assessed through continuous evaluation including map tests, chapter tests and exams, writing activities, computerized activities, class participation as well as individual and group works.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": {
                        "pre": [["GEO109E130"]],
