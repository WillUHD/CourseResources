            ], "12": [
                {   "id": "HIS112E110",
                    "name": "Western Civilization 2 12 Standard",
                    "track": "school",
                    "level": "S",
                    "description": "Western Civilization covers the development of the modern European world. After identifying the characteristics of modern Europe developed during the Enlightenment, the class will explore modern European history from the French Revolution until the end of the Cold War. The emphasis will be on the growth of absolutism, imperialism, socialism and totalitarianism. This history class will be influenced by the humanities and focus on culture (art, music and architecture), philosophy, religion and literature and how they have contributed to developing modern Europe. Homework Expectation: 2-3 hours per week",
                    "crowdRating": 0.0,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": { "pre": [["HIS111E112"]] }
                }, { "id": "HIS112E130",
                    "name": "Western Civilization 2 12 Honors",
                    "track": "school",
                    "level": "H",
                    "description": "Western Civilization is a twelfth grade honors level course that covers the development of the modern European world. After identifying the characteristics of modern Europe developed during the Enlightenment, the class will explore modern European history from the French Revolution until the end of the Cold War. The emphasis will be on the growth of absolutism, imperialism, socialism and totalitarianism. This history class will be influenced by the humanities and focus on culture (art, music and architecture), philosophy, religion and literature and how they have contributed to developing modern Europe.In addition to lectures or PPT presentations on important themes of European history, students are expected to participate in class orally through discussions of primary documents, readings and events, debates of key issues, possible role-playing of historic figures, re-enactments and mock trials.Emphasis is placed on critical thinking skills, essay writing, the interpretation of original documents and historiography. Students will be required to apply the effort necessary to act as an historian and develop the ability to analyze historical evidence to determine its validity and relevance, identify point of view and the nature of bias, and recognize the necessity of objectivity and substantiation. Homework Expectation: 3-4 hours per week",
                    "crowdRating": 0.0,
                    "crowdReview": "ISA - Hack the system. Build the future.",
