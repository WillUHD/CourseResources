                }, { "id": "CHI010E170",
                    "name": "AP Chinese 10 (AP)",
                    "track": "AP",
                    "level": "AP",
                    "description": "Both language skills and culture awareness are emphasized. The objective of the course is clear and effective communication through the understanding and usage of a range of essential spoken and written forms of the language. Vocabulary and expressions of common usage will be the key focus. While the speaking and the listening skills are emphasized, the reading and writing skills are required as well. All students enrolled in an AP subject must take the external exam at the end of the year.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": {
                        "pre": [["CHI009E005", "CHI009E006", "CHI009E110"]], 
                        "next": [["CHI011E160"]]
                    }
                }, { "id": "CHI010E110",
                    "name": "Chinese Level 8 10 (S)",
                    "track": "school",
                    "level": "S",
                    "description": "This course primarily aims to assist students in mastering the fundamentals of Chinese characters, vocabulary, and grammar, different narrative techniques used interchangeably; reasoning by material, classification and comparison talk methods. providing a foundation for training in both written and oral expression. It serves as a preparatory course for choosing the IB Chinese B HL program.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": {
                        "pre": [["CHI009E110"]], "next": [["CHI011E110", "CHI011E160"]]
                    }
                }, { "id": "CHI010E120",
                    "name": "Chinese Level 9 10 (H)",
                    "track": "school",
                    "level": "H",
                    "description": "The course is designed to enable students to master several descriptions of the relevant figures; different approaches for description of the scene, such as subjective description and objective description of positive description and side contrast; contrast narrative lyric; different narrative techniques used interchangeably; reasoning by material, classification and comparison talk methods. Students will also learn the classical literature and poetry. They are required to grasp basic skills of reading classical Chinese literature texts. It serves as a preparatory course for choosing the IB Chinese A language program.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": {
                        "pre": [["CHI009E120"]], 
                        "next": [["CHI011E120", "CHI011E130", "CHI011E160"]]
                    }
                }, { "id": "CHI010E130",
                    "name": "Chinese Level 10 10 (H+)",
                    "track": "school",
                    "level": "H+",
                    "description": "Chinese Level X is an advanced literature course designed for students who have demonstrated strong proficiency in Chinese and a keen interest in literary studies. The course aims to deepen students' engagement with Chinese literature while enhancing their analytical and critical thinking skills. Through Level X, students will: Explore a wide range of literary genres and works. Develop refined close-reading and textual analysis abilities. Begin training in literary essay writing, learning to articulate independent viewpoints. Encounter a higher level of challenge in both reading volume and intellectual depth compared to Level IX. The course is particularly suited for high-achieving Level IX students who are passionate about literature and may consider pursuing IB Chinese Language A in the future. It serves as an excellent preparatory pathway, helping students adapt to the demands of IB-level literary study.",
                    "crowdRating": 6.7,
                    "crowdReview": "ISA - Hack the system. Build the future.",
                    "rules": {
                        "pre": [["CHI009E120", "CHI009E130"]], 
                        "next": [["CHI011E130", "CHI011E160"]]
                    }
                }
