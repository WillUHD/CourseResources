        }, "history": {
            "9": [
                {   "id": "HIS009E110",
                    "name": "World History to 1500 9 Standard",
                    "track": "school",
                    "level": "S",
                    "description": "This course will be taught in a chronological sequence. The focus of this course is the study of the historical development of peoples, places, and patterns of life from ancient times until 1500 AD. Students will start with Prehistory and move into the earliest civilizations that developed in the River Valleys of Africa, Asia, and Europe. The students will then work their way through the classical civilizations of Egypt, Early India & China, Greece, and Rome. Next, they will study the Middle Ages, the Renaissance, and the Reformation. The class will finish with the Age of Exploration and Conquest. Students will use skills of historical and geographical analysis to explore the early history of the world. Homework Expectation: 2 hours per week",
                    "crowdRating": 0.0,
                    "crowdReview": "ISA - Hack the system. Build the future."
                }, { "id": "HIS009E120",
                    "name": "World History to 1500 9 S+",
                    "track": "school",
                    "level": "S+",
                    "description": "This course will be taught in a chronological sequence. The focus of this course is the study of the historical development of people, places, and patterns of life from ancient times until 1500 AD. Students will start with Prehistory and move into the earliest civilizations that developed in the River Valleys of Africa, Asia, and Europe. The students will then work their way through the classical civilizations of Egypt, Early India & China, Greece, and Rome. Next, they will study the Middle Ages, the Renaissance, and the Reformation. The class will finish with the Age of Exploration and Conquest. Lectures, readings, assignments, and discussions are designed to offer insights into the cultural, economic, political, religious, and social aspects of human experience; special attention will be given to cross-cultural interactions and exchange up to the 1500. Homework Expectation: 2-3 hours per week",
                    "crowdRating": 0.0,
