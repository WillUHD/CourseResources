        "rules": {
            "exclusionTags": [["AP", "nonAP"]],
            "exclusionIds": [["g11_m2_ap_micro", "g11_m4_ap_micro", "g11_m4_maybe_same_micro"],
                ["g11_m2_ap_macro", "g11_m4_ap_macro", "g11_m4_maybe_same_macro"]
            ],
            "dynamicLimits": [{
                    "triggerModuleIndex": 2,
                    "triggerCondition": ">= 2", "targetModuleIndices": [4, 5],
                    "newLimit": 0
                }
            ],
            "conditionalRequirements": [{
                    "id": "econ_ap_rule", "trigger": {
                        "selectedSubjectIds": ["g11_m2_ap_micro", "g11_m2_ap_macro"],
                        "moduleConditions": [{"moduleIndex": 2, "minSelected": 1, "requireTag": "AP", "exactCount": 1}]
                    },
                    "requiresAnyOfSubjectIds": ["g11_m4_ap_draw", "g11_m4_ap_3d"],
