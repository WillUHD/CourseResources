{ "catalogName": "SHSID Course Catalog - Spring 2026",
  "version": "3.4",
  "lastUpdated": "April 1, 2026",
  "credit": "Catalog by willuhd, original project by Michel",
  
  // the order in which the score map is defined matters
  // for instance, defining A+ first will reverse the selector
  // (though it won't make the GPA calculation incorrect)
  "scoreMaps": {
    "default": [
        {"percent": "0",  "letter": "F",    "gpa": 0.0},
        {"percent": "60", "letter": "D/C",  "gpa": 2.6},
        {"percent": "68", "letter": "C+",   "gpa": 3.0},
        {"percent": "73", "letter": "B-",   "gpa": 3.3},
        {"percent": "78", "letter": "B",    "gpa": 3.6},
        {"percent": "83", "letter": "B+",   "gpa": 3.9},
        {"percent": "88", "letter": "A-",   "gpa": 4.2},
        {"percent": "93", "letter": "A/A+", "gpa": 4.5}
    ],
    "AP": [
        {"percent": "1", "letter": "1", "gpa": 0.0},
        {"percent": "2", "letter": "2", "gpa": 1.0},
        {"percent": "3", "letter": "3", "gpa": 2.5},
        {"percent": "4", "letter": "4", "gpa": 3.5},
        {"percent": "5", "letter": "5", "gpa": 4.5}
    ],
    "ASA2": [
        {"percent": "U", "letter": "U", "gpa": 0.0},
        {"percent": "E", "letter": "E", "gpa": 1.0},
        {"percent": "D", "letter": "D", "gpa": 2.5},
        {"percent": "C", "letter": "C", "gpa": 3.0},
        {"percent": "B", "letter": "B", "gpa": 3.5},
        {"percent": "A", "letter": "A", "gpa": 4.0},
        {"percent": "A*", "letter": "A*", "gpa": 4.5}
    ],
    "IB": [
        {"percent": "1", "letter": "1", "gpa": 0.0},
        {"percent": "2", "letter": "2", "gpa": 2.0},
        {"percent": "3", "letter": "3", "gpa": 2.5},
        {"percent": "4", "letter": "4", "gpa": 3.0},
        {"percent": "5", "letter": "5", "gpa": 3.5},
        {"percent": "6", "letter": "6", "gpa": 4.0},
        {"percent": "7", "letter": "7", "gpa": 4.5}
