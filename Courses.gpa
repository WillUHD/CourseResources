                        {"moduleIndex": 2, "newLimit": 1},
                        {"moduleIndex": 4,"newLimit": 0}
                    ], "errorMessage": "Selecting AP ES requires 1xM1 (and M3 is disabled :P)"
                }
            ],
            "requirements": [{
                    "triggerTag": "AP", "requiredAnyTag": ["AP"],
                    "errorMessage": "??? how did you get the app to run in this state bro"
                }
            ]
